# --- Path Configurations ---
HOSTS_FILE="/etc/hosts"
CONFIG_DIR="$HOME/.config/htbip"
DOMAINS_FILE="$CONFIG_DIR/domains.conf"
START_MARKER="# IPs HTB - BEGIN"
END_MARKER="# IPs HTB - END"

# --- Default Domains ---
DEFAULT_DOMAINS=(
    "htb.local"
    "htb.htb"
    "inlanefreight.local"
    "inlanefreight.htb"
	"blog.inlanefreight.local"
	"blog.inlanefreight.htb"
	"support.inlanefreight.local"
	"support.inlanefreight.htb"
	"customer.inlanefreight.local"
	"customer.inlanefreight.htb"
    "app.inlanefreight.local"
    "app.inlanefreight.htb"
    "dev.inlanefreight.local"
    "dev.inlanefreight.htb"
	"my.inlanefreight.local"
	"my.inlanefreight.htb"
	"www.inlanefreight.local"
	"www.inlanefreight.htb"
	"ns1.inlanefreight.local"
	"ns1.inlanefreight.htb"
	"ns2.inlanefreight.local"
	"ns2.inlanefreight.htb"
	"ns3.inlanefreight.local"
	"ns3.inlanefreight.htb"
	"mail.inlanefreight.local"
	"mail.inlanefreight.htb"
	"corp.inlanefreight.local"
	"corp.inlanefreight.htb"
	"dc01.inlanefreight.local"
	"dc01.inlanefreight.htb"
	"sql01.inlanefreight.local"
	"sql01.inlanefreight.htb"
	"ilfreight.local"
	"ilfreight.htb"
	"hackthebox.local"
	"hackthebox.htb"
)

# --- Initialization ---
mkdir -p "$CONFIG_DIR"
if [ ! -f "$DOMAINS_FILE" ]; then
    printf "%s\n" "${DEFAULT_DOMAINS[@]}" > "$DOMAINS_FILE"
fi

mapfile -t DOMAINS < "$DOMAINS_FILE"

# --- Utility Functions ---

do_backup() {
    local TIMESTAMP=$(date +%Y%m%d_%H%M%S)
    local BACKUP_FILE="${HOSTS_FILE}.bak_${TIMESTAMP}"
    sudo cp "$HOSTS_FILE" "$BACKUP_FILE"
    echo "💾 Automatic backup created: $BACKUP_FILE"
}

check_sudo() {
    if [ "$EUID" -ne 0 ]; then
        echo "🔐 Root privileges required. Re-running with sudo..."
        exec sudo "$0" "$@"
    fi
}

show_help() {
    echo -e "\n  ====== 🚀 HTBIP MANAGER - HELP ======\n"
    echo "    Usage: htbip <IP> [options]"
    echo -e "\n    MAIN OPTIONS:"
    echo "      <IP>                Adds the IP with all default domains."
    echo "      -e, --choose        Interactive menu to select domains."
    echo "      -d, --defaults      List all domains configured as default."
    echo "      -u, --url \"doms\"    Add custom domains for this specific IP."
    echo -e "\n    MANAGEMENT:"
    echo "      -l, --list          List ACTIVE hosts in the HTB section."
    echo "      -c, --clear         Clear ALL hosts from the HTB section."
    echo "      -r, --remove <IP>   Remove a specific IP from the section."
    echo "      -o, --open          Open the hosts file in nano (sudo)."
    echo -e "\n    UTILITIES:"
    echo "      -p, --ping          Test connectivity of IPs in the section."
    echo "      -b, --backup        Create a manual backup of /etc/hosts."
    echo "      -ec, --edit-conf    Edit the default domains configuration file."
	echo "      -rc, --reset-conf   Reset domains.conf to script defaults."
    echo "      -h, --help          Show this help menu."
    echo -e "\n  =====================================\n"
}

# --- Execution Logic ---

if [[ $# -eq 0 ]]; then show_help; exit 0; fi

# Commands that don't need sudo/backup immediately
case "$1" in
    --edit-conf) ${EDITOR:-nano} "$DOMAINS_FILE"; exit 0 ;;
	--reset-conf) printf "%s\n" "${DEFAULT_DOMAINS[@]}" > "$DOMAINS_FILE"; echo "🔄 Configuration reset to code defaults."; exit 0 ;;
    -d|--defaults) printf "  - %s\n" "${DOMAINS[@]}"; exit 0 ;;
    -h|--help) show_help; exit 0 ;;
esac

# Commands that MODIFY /etc/hosts (Require sudo and auto-backup)
case "$1" in
    -c|--clear|-b|--backup|-r|--remove|-o|--open|-u|--url|*)
        check_sudo "$@"
        [[ "$1" != "-o" && "$1" != "--open" ]] && do_backup
        ;;
esac

case "$1" in
    -o|--open) 
        sudo nano "$HOSTS_FILE" 
        exit 0 ;;

    -c|--clear)
        sudo sed -i "/$START_MARKER/,/$END_MARKER/{//!d}" "$HOSTS_FILE"
        echo "🧹 HTB Section cleared."
        exit 0 ;;

    -r|--remove)
        if [ -z "$2" ]; then echo "❌ Error: Specify an IP to remove."; exit 1; fi
        sudo sed -i "/$START_MARKER/,/$END_MARKER/{/^$2[[:space:]]/d}" "$HOSTS_FILE"
        echo "❌ IP $2 removed."
        exit 0 ;;

    -l|--list)
        sed -n "/$START_MARKER/,/$END_MARKER/p" "$HOSTS_FILE" | grep -v "HTB -"
        exit 0 ;;

    -p|--ping)
        ips=$(sed -n "/$START_MARKER/,/$END_MARKER/p" "$HOSTS_FILE" | grep -E -o "([0-9]{1,3}[\.]){3}[0-9]{1,3}" | sort -u)
        for i in $ips; do 
            ping -c 1 -W 1 $i > /dev/null && echo "✅ $i ONLINE" || echo "❌ $i OFFLINE"
        done
        exit 0 ;;

    -b|--backup) echo "✅ Manual backup completed."; exit 0 ;;

    *)
        IP="$1"
        if [[ ! $IP =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]]; then
            echo "❌ Error: Invalid IP address."; exit 1
        fi
        
        SELECTED_DOMAINS=()
        shift
        
        while [[ $# -gt 0 ]]; do
            case $1 in
                -u|--url) IFS=' ' read -r -a SELECTED_DOMAINS <<< "$2"; shift 2 ;;
                -e|--choose)
                    echo "Select hosts (e.g., 125):"
                    for i in "${!DOMAINS[@]}"; do echo "$((i+1))) ${DOMAINS[$i]}"; done
                    read -p "Input: " choice
                    for (( i=0; i<${#choice}; i++ )); do
                        idx=$(( ${choice:$i:1} - 1 ))
                        [[ $idx -ge 0 && $idx -lt ${#DOMAINS[@]} ]] && SELECTED_DOMAINS+=("${DOMAINS[$idx]}")
                    done
                    shift ;;
                *) shift ;;
            esac
        done

        # If no specific domains selected via -u or -e, use defaults
        if [ ${#SELECTED_DOMAINS[@]} -eq 0 ]; then SELECTED_DOMAINS=("${DOMAINS[@]}"); fi

        # Mapping process
        for dom in "${SELECTED_DOMAINS[@]}"; do
            sudo sed -i "/$START_MARKER/,/$END_MARKER/{/[[:space:]]$dom$/d}" "$HOSTS_FILE"
            sudo sed -i "/$END_MARKER/i $IP\t$dom" "$HOSTS_FILE"
        done
        echo "✅ Mapping completed for $IP"
        ;;
esac
