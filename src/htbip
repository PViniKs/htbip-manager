# --- Path Configurations ---
HOSTS_FILE="/etc/hosts"
CONFIG_DIR="/home/$(logname)/.config/htbip"
DOMAINS_FILE="$CONFIG_DIR/domains.conf"
START_MARKER="# IPs HTB - BEGIN"
END_MARKER="# IPs HTB - END"

# --- Initialization ---
mkdir -p "$CONFIG_DIR"
REMOTE_URL="https://raw.githubusercontent.com/PViniKs/htbip-manager/refs/heads/main/hosts.txt"

# Função interna para baixar e processar a lista do GitHub
sync_from_github() {
    echo "🌐 Synchronizing domains from GitHub..."
    local RAW_DATA=$(curl -s "$REMOTE_URL")

    if [ -z "$RAW_DATA" ]; then
        echo "⚠️ Warning: Could not reach GitHub. Using local domains.conf if available."
        return 1
    fi

    # Limpa o arquivo e reconstrói com as extensões
    > "$DOMAINS_FILE"
    while IFS= read -r line; do
        line=$(echo "$line" | xargs)
        [[ -z "$line" ]] && continue
        echo "${line}.local" >> "$DOMAINS_FILE"
        echo "${line}.htb" >> "$DOMAINS_FILE"
    done <<< "$RAW_DATA"
    return 0
}

# SÓ executa o download se o arquivo NÃO existir localmente 
if [ ! -f "$DOMAINS_FILE" ]; then
    sync_from_github
fi

# Carrega os domínios para a memória (DOMAINS) 
if [ -f "$DOMAINS_FILE" ]; then
    mapfile -t DOMAINS < "$DOMAINS_FILE"
else
    echo "❌ Error: Domains file not found and GitHub unreachable."
    exit 1
fi

# --- Utility Functions ---

do_backup() {
    local TIMESTAMP=$(date +%Y%m%d_%H%M%S)
    local BACKUP_FILE="${HOSTS_FILE}.bak_${TIMESTAMP}"
    sudo cp "$HOSTS_FILE" "$BACKUP_FILE"
    echo "💾 Automatic backup created: $BACKUP_FILE"
}

check_sudo() {
    if [ "$EUID" -ne 0 ]; then
        echo "🔐 Root privileges required. Re-running with sudo..."
        exec sudo "$0" "$@"
    fi
}

show_help() {
    echo -e "\n  ====== 🚀 HTBIP MANAGER - HELP ======\n"
    echo "    Usage: htbip <IP> [options]"
    echo -e "\n    MAIN OPTIONS:"
    echo "      <IP>                  Adds the IP with all default domains."
    echo "      -e, --choose          Interactive menu to select domains."
    echo "      -d, --defaults        List all domains configured as default."
    echo "      -u, --url \"doms\"      Add custom domains for this specific IP."
    echo -e "\n    MANAGEMENT:"
    echo "      -l, --list            List ACTIVE hosts in the HTB section."
	echo "      -es, --export-scope   Export active domains and IPs to a .txt file."
    echo "      -c, --clear           Clear ALL hosts from the HTB section."
    echo "      -r, --remove <IP>     Remove a specific IP from the section."
    echo "      -o, --open            Open the hosts file in nano (sudo)."
    echo -e "\n    UTILITIES:"
    echo "      -p, --ping            Test connectivity of IPs in the section."
    echo "      -b, --backup          Create a manual backup of /etc/hosts."
    echo "      -ec, --edit-conf      Edit the default domains configuration file."
	echo "      -rc, --reset-conf     Reset domains.conf to script defaults."
    echo "      -h, --help            Show this help menu."
    echo -e "\n  =====================================\n"
}

# --- Execution Logic ---

if [[ $# -eq 0 ]]; then show_help; exit 0; fi

# Commands that don't need sudo/backup immediately
case "$1" in
	-es|--export-scope)
        # Define o nome do arquivo com a data e hora atual
        TIMESTAMP=$(date +%Y%m%d%H%M)
        OUTPUT_FILE="scope_list_${TIMESTAMP}.txt"

        # get content
        # extract hosts (2nd column)
        # extract ips   (1st column)
        # get rid of dupes and save into file

        {
            sed -n "/$START_MARKER/,/$END_MARKER/p" "$HOSTS_FILE" | grep -v "HTB -" | awk '{print $2}'
            sed -n "/$START_MARKER/,/$END_MARKER/p" "$HOSTS_FILE" | grep -v "HTB -" | awk '{print $1}'
        } | sort -u > "$OUTPUT_FILE"

        echo "📄 Scope exported to: $OUTPUT_FILE"
        exit 0 ;;
    -ec|--edit-conf)
        ${EDITOR:-nano} "$DOMAINS_FILE"
        exit 0 ;;
    -rc|--reset-conf)
        rm -f "$DOMAINS_FILE"
        sync_from_github
        mapfile -t DOMAINS < "$DOMAINS_FILE" # Atualiza a memória após o reset 
        echo "🔄 Configuration reset and resynced from GitHub."
        exit 0 ;;
    -d|--defaults) printf "  - %s\n" "${DOMAINS[@]}"; exit 0 ;;
    -h|--help) show_help; exit 0 ;;
esac

# Commands that MODIFY /etc/hosts (Require sudo and auto-backup)
case "$1" in
    -c|--clear|-b|--backup|-r|--remove|-o|--open|-u|--url|*)
        check_sudo "$@"
        ;;
esac

case "$1" in
    -o|--open)
    	do_backup
        sudo nano "$HOSTS_FILE"
        exit 0 ;;

    -c|--clear)
    	do_backup
        sudo sed -i "/$START_MARKER/,/$END_MARKER/{//!d}" "$HOSTS_FILE"
        echo "🧹 HTB Section cleared."
        exit 0 ;;

    -r|--remove)
    	do_backup
        if [ -z "$2" ]; then echo "❌ Error: Specify an IP to remove."; exit 1; fi
        sudo sed -i "/$START_MARKER/,/$END_MARKER/{/^$2[[:space:]]/d}" "$HOSTS_FILE"
        echo "❌ IP $2 removed."
        exit 0 ;;

    -l|--list)
        sed -n "/$START_MARKER/,/$END_MARKER/p" "$HOSTS_FILE" | grep -v "HTB -"
        exit 0 ;;

    -p|--ping)
        ips=$(sed -n "/$START_MARKER/,/$END_MARKER/p" "$HOSTS_FILE" | grep -E -o "([0-9]{1,3}[\.]){3}[0-9]{1,3}" | sort -u)
        for i in $ips; do 
            ping -c 1 -W 1 $i > /dev/null && echo "✅ $i ONLINE" || echo "❌ $i OFFLINE"
        done
        exit 0 ;;

    -b|--backup)
		do_backup
        echo "✅ Manual backup completed."
        exit 0 ;;

	*)
    
    # Se o primeiro argumento for -u, entramos no modo interativo total
    if [[ "$1" == "-u" || "$1" == "--url" ]]; then
		do_backup
        read -p "🌐 Enter Target IP: " IP
        if [[ ! $IP =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]]; then
            echo "❌ Error: Invalid IP address."; exit 1
        fi
        
        SELECTED_DOMAINS=()
        echo "📝 Enter URLs one by one (Type 'ok' or press ENTER to finish):"
        while true; do
            read -p "> " url_input
            # Para se digitar 'ok' ou apenas der Enter no vazio
            [[ "$url_input" == "ok" || -z "$url_input" ]] && break
            SELECTED_DOMAINS+=("$url_input")
        done
    else
        # Comportamento padrão: htbip <IP> [options]
        IP="$1"
        if [[ ! $IP =~ ^[0-9]{1,3}(\.[0-9]{1,3}){3}$ ]]; then
            echo "❌ Error: Invalid IP address."; exit 1
        fi
        
        SELECTED_DOMAINS=()
        shift
        
        while [[ $# -gt 0 ]]; do
            case $1 in
                -u|--url)
                    do_backup
                    shift
                    # Se houver argumentos após o -u, captura-os
                    while [[ $# -gt 0 && ! $1 =~ ^- ]]; do
                        SELECTED_DOMAINS+=("$1")
                        shift
                    done ;;
                -e|--choose)
					do_backup
                    echo "Select hosts separated by SPACE (e.g., 1 2 15):"
                    for i in "${!DOMAINS[@]}"; do printf "%2d) %s\n" "$((i+1))" "${DOMAINS[$i]}"; done
                    read -p "Input: " choices
                    for choice in $choices; do
                        idx=$(( choice - 1 ))
                        [[ $idx -ge 0 && $idx -lt ${#DOMAINS[@]} ]] && SELECTED_DOMAINS+=("${DOMAINS[$idx]}")
                    done
                    shift ;;
                *) shift ;;
            esac
        done
    fi

    # Se nenhuma URL foi selecionada, usa o padrão do domains.conf
    if [ ${#SELECTED_DOMAINS[@]} -eq 0 ]; then SELECTED_DOMAINS=("${DOMAINS[@]}"); fi

    # Processo de Mapeamento no /etc/hosts
    for dom in "${SELECTED_DOMAINS[@]}"; do
        sudo sed -i "/$START_MARKER/,/$END_MARKER/{/[[:space:]]$dom$/d}" "$HOSTS_FILE"
        sudo sed -i "/$END_MARKER/i $IP\t$dom" "$HOSTS_FILE"
    done
    echo "✅ Mapping completed for $IP"
    ;;
esac
